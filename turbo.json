{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": ["dist/**"],
      "env": [
        "DATABASE_URL",
        "CORS_ORIGIN",
        "NODE_ENV",
        "GROQ_API_KEY",
        "JWT_SECRET",
        "JWT_REFRESH_SECRET",
        "JWT_ACCESS_TOKEN_EXPIRY",
        "JWT_REFRESH_TOKEN_EXPIRY",
        "VITE_SERVER_URL"
      ]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "db:push": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false,
      "persistent": true
    },
    "db:studio": {
      "cache": false,
      "persistent": true
    }
  }
}
