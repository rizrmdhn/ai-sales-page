{
  "name": "@ai-sales-page/api",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsc",
    "lint": "eslint",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "@ai-sales-page/ai": "workspace:*",
    "@ai-sales-page/auth": "workspace:*",
    "@ai-sales-page/db": "workspace:*",
    "@ai-sales-page/queries": "workspace:*",
    "@ai-sales-page/env": "workspace:*",
    "@ai-sales-page/schema": "workspace:*",
    "@ai-sales-page/utils": "workspace:*",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "dotenv": "catalog:",
    "zod": "catalog:",
    "superjson": "catalog:",
    "@node-rs/argon2": "catalog:",
    "uuid": "catalog:"
  },
  "devDependencies": {
    "@ai-sales-page/config": "workspace:*",
    "hono": "catalog:",
    "typescript": "catalog:",
    "@types/node": "catalog:"
  }
}
